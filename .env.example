# YAML-backed settings only use these values when config.yml references them
# with ${...}. Literal YAML values are not overridden.
MAINNET_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
ETHERSCAN_API_KEY=

# Runtime-only backend settings read directly from the process environment.
COINGECKO_API_KEY=

# Docker host ports read by Docker Compose. The backend container still listens
# on 8080 internally.
TXSIM_BACKEND_PORT=8080
TXSIM_FRONTEND_PORT=5173

# Docker Foundry workspace mount. Default host path is the parent directory of
# this repo, mounted to /workspace/projects.
TXSIM_PROJECTS_HOST_PATH=..
TXSIM_PROJECTS_CONTAINER_PATH=/workspace/projects

# App settings such as listen_addr, frontend_port, and anvil_port_start live in config.yml.
