MAINNET_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=

# These values are loaded only when backend/config.yml or backend/config.example.yaml references
# them with ${...}. They do not override literal YAML config values.

# Docker host ports. The backend container still listens on 8080 internally.
TXSIM_BACKEND_PORT=8080
TXSIM_FRONTEND_PORT=5173

# Docker Foundry workspace mount. Default host path is the parent directory of
# this repo, mounted to /workspace/projects.
TXSIM_PROJECTS_HOST_PATH=..
TXSIM_PROJECTS_CONTAINER_PATH=/workspace/projects

# Backend runtime settings such as listen_addr and anvil_port_start live in backend/config.yml.
